<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<fx:root type="BorderPane"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <!-- DATE -->
    <top>
        <Label fx:id="dateLabel"
               styleClass="task-date-lbl"
               wrapText="true"
               alignment="CENTER"
               textAlignment="CENTER"
               maxWidth="1000"
               prefWidth="1000"
               minWidth="1000"/>
    </top>

    <center>
        <VBox alignment="TOP_CENTER"
              spacing="20"
              maxWidth="1000"
              prefWidth="1000"
              minWidth="1000"
              BorderPane.alignment="CENTER">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- ===== TITLE SECTION ===== -->
            <VBox alignment="CENTER" spacing="10">

                <Label fx:id="titleLabel"
                       styleClass="task-description-lbl"
                       wrapText="true"
                       maxWidth="550"
                       alignment="CENTER"
                       textAlignment="CENTER"/>

                <Label fx:id="stateLabel"
                       styleClass="task-state-lbl"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       text="COMPLETED"/>

            </VBox>

            <!-- ===== BOTTOM SECTION ===== -->
            <VBox alignment="CENTER" spacing="25">
                <HBox alignment="CENTER_RIGHT">
                    <GridPane fx:id="workersGrid"
                              hgap="15"
                              vgap="15"
                              maxWidth="300">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints percentHeight="100"/>
                        </rowConstraints>

                    </GridPane>

                </HBox>

                <Button fx:id="resetButton"
                        text="RESET TASK"
                        styleClass="styled-btn"/>

                <HBox alignment="CENTER" spacing="20">

                    <Button fx:id="deleteButton"
                            text="DELETE TASK"
                            styleClass="styled-btn-red"/>

                    <Region HBox.hgrow="ALWAYS"/>

                    <Button fx:id="closeButton"
                            text="CLOSE CARD"
                            styleClass="styled-btn-black"/>

                </HBox>

            </VBox>

        </VBox>
    </center>
</fx:root>
