<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.unimib.assignment3.UI.view.controller.TaskCreationFormController"
      spacing="15"
      alignment="CENTER"
      styleClass="task-creation-form">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- LABEL -->
    <Label fx:id="insertEmailLabel"
           text="Fill in the details to create a new task"
           styleClass="insert-email-lbl"
           maxWidth="Infinity"
           alignment="CENTER"/>

    <!-- EMAIL FIELD -->
    <TextField fx:id="descriptionField"
               promptText="Enter the task description"
               styleClass="input-form"
               prefHeight="45"
               maxWidth="300"/>

    <!-- BUTTON -->
    <Button fx:id="submitButton"
            text="SUBMIT"
            styleClass="styled-btn"/>

</VBox>
