<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.Region?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.unimib.assignment3.UI.view.controller.TaskCreationFormController"
           fx:id="root"
           styleClass="task-creation-overlay">

    <!-- BACKGROUND RECTANGLE -->
    <Rectangle fx:id="backgroundLayer" fill="#00000080"/>

    <!-- CENTERED FORM -->
    <VBox spacing="15"
          alignment="CENTER"
          styleClass="task-creation-form"
          maxHeight="300"
          maxWidth="400">

        <Label text="Fill in the details to create a new task"
               styleClass="insert-email-lbl"
               alignment="CENTER"/>

        <TextField fx:id="descriptionField"
                   promptText="Enter the task description"
                   styleClass="input-form"
                   prefHeight="45"
                   maxWidth="300"/>

        <Region prefHeight="10"/>

        <Button fx:id="submitButton"
                text="SUBMIT"
                styleClass="styled-btn"/>

    </VBox>

</StackPane>