<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<fx:root type="VBox"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         prefWidth="400"
         prefHeight="400"
         spacing="10"
         styleClass="design-rectangle">

    <!-- ========================= -->
    <!-- CHAT LIST -->
    <!-- ========================= -->
    <VBox fx:id="chats"
          spacing="10"
          prefWidth="200"
          alignment="TOP_CENTER">
        <Label text="CHATS"
               styleClass="insert-text-lbl"
               maxWidth="Infinity"
               alignment="CENTER"
               textAlignment="CENTER"/>
    </VBox>

    <!-- ========================= -->
    <!-- CHAT AREA -->
    <!-- hidden until chat is selected -->
    <!-- ========================= -->
    <VBox fx:id="chatArea"
          spacing="10"
          visible="false"
          managed="false"
          VBox.vgrow="ALWAYS">
        <!-- BACK BUTTON -->
        <Button fx:id="backButton"
                text="← Back"
                styleClass="styled-btn"/>
        <!-- MESSAGES -->
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    VBox.vgrow="ALWAYS"
                    styleClass="transparent-scroll">
            <VBox fx:id="chatContainer"
                  spacing="10"/>
        </ScrollPane>
        <!-- INPUT AREA -->
        <HBox spacing="5">
            <TextField fx:id="inputForm"
                       promptText="Enter message..."
                       HBox.hgrow="ALWAYS"
                       styleClass="input-form"/>
            <Button fx:id="sendButton"
                    text="Send"
                    styleClass="styled-btn"/>
        </HBox>
    </VBox>

</fx:root>