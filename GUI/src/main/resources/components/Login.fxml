<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.layout.Region?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1"
         spacing="20"
         alignment="CENTER">

    <StackPane fx:id="rootStack" prefWidth="800" prefHeight="600">

        <!-- Decorative rectangle -->
        <Rectangle fx:id="designRectangle"
                   width="420"
                   height="230"
                   arcWidth="28"
                   arcHeight="28"
                   translateY="-20"
                   styleClass="design-rectangle"/>

        <!-- Decorative oval (will be clipped) -->
        <Ellipse fx:id="designOval"
                 radiusX="240"
                 radiusY="140"
                 translateY="145"
                 styleClass="design-oval"/>

        <!-- FORM -->
        <VBox spacing="18"
              alignment="CENTER"
              maxWidth="380"
              translateY="-10">

            <Label fx:id="insertEmailLabel"
                   text="INSERT YOUR EMAIL TO LOGIN"
                   styleClass="insert-email-lbl"
                   wrapText="true"
                   alignment="CENTER"
                   maxWidth="Infinity"
                   prefWidth="Infinity">
                <VBox.margin>
                    <Insets top="0" right="0" bottom="0" left="0"/>
                </VBox.margin>
            </Label>

            <TextField fx:id="inputForm"
                       promptText="Enter your email"
                       styleClass="input-form"
                       maxWidth="Infinity"
                       prefWidth="Infinity">
                <VBox.margin>
                    <Insets top="0" right="10" bottom="0" left="10"/>
                </VBox.margin>
            </TextField>

            <Region fx:id="spacer" prefHeight="5"/>

            <Button fx:id="submitButton"
                    text="SUBMIT"
                    styleClass="styled-btn"
                    prefWidth="110"
                    prefHeight="36"/>

            <Region fx:id="spacer" prefHeight="5"/>
        </VBox>

    </StackPane>

</fx:root>