<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.layout.Region?>

<fx:root type="javafx.scene.layout.VBox"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1"
         spacing="20"
         alignment="CENTER">

    <StackPane fx:id="rootStack" prefWidth="800" prefHeight="600">

        <Rectangle fx:id="designRectangle"
                   width="470"
                   height="290"
                   arcWidth="20"
                   arcHeight="28"
                   translateY="-20"
                   styleClass="design-rectangle"/>


        <!-- FORM: same width as rectangle, centered -->
        <VBox spacing="0"
              alignment="CENTER"
              prefWidth="426"
              maxWidth="426"
              translateY="-20">

            <!-- Top spacer (equal to bottom spacer) -->
            <Region VBox.vgrow="ALWAYS"/>

            <Label fx:id="insertEmailLabel"
                   text="INSERT YOUR EMAIL TO LOGIN"
                   styleClass="insert-email-lbl"
                   wrapText="true"
                   alignment="CENTER"
                   maxWidth="Infinity"
                   prefWidth="Infinity"/>

            <Region prefHeight="20"/>

            <TextField fx:id="inputForm"
                       promptText="Enter your email"
                       styleClass="input-form"
                       maxWidth="Infinity"
                       prefWidth="Infinity">
                <VBox.margin>
                    <Insets left="10" right="10"/>
                </VBox.margin>
            </TextField>

            <Region prefHeight="30"/>

            <Button fx:id="submitButton"
                    text="SUBMIT"
                    styleClass="styled-btn"
                    prefWidth="110"
                    prefHeight="36"/>

            <!-- Bottom spacer (mirrors top spacer) -->
            <Region VBox.vgrow="ALWAYS"/>

        </VBox>

    </StackPane>

</fx:root>