<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.RowConstraints?>

<fx:root type="javafx.scene.layout.BorderPane"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml">

    <!-- PADDING GENERALE -->
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <center>
        <VBox alignment="CENTER" spacing="40">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- MIDDLE SECTION -->
            <VBox alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <Label fx:id="titleLabel"
                       styleClass="task-description-lbl"/>
                <Label fx:id="stateLabel"
                       styleClass="task-state-lbl"/>
            </VBox>

            <!-- BOTTOM SECTION -->
            <VBox alignment="CENTER" spacing="20">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>

                <HBox alignment="CENTER_LEFT">
                    <Button fx:id="acceptButton"
                            styleClass="styled-btn"
                            text="ACCEPT"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <GridPane fx:id="workersGrid"
                              hgap="15"
                              vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50"/>
                            <ColumnConstraints percentWidth="50"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints percentHeight="100"/>
                        </rowConstraints>
                    </GridPane>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Button fx:id="resetButton"
                            styleClass="styled-btn"
                            text="RESET"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="changeStateButton"
                            styleClass="styled-btn"/>
                </HBox>

            </VBox>

        </VBox>
    </center>

</fx:root>
