<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="BorderPane"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1">

    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <!-- DATE -->
    <top>
        <Label fx:id="dateLabel" alignment="CENTER" maxWidth="550" styleClass="task-date-lbl" textAlignment="CENTER" wrapText="true" />
    </top>

    <center>
        <VBox alignment="TOP_CENTER" maxWidth="600" prefWidth="600" spacing="20" BorderPane.alignment="CENTER">

            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <!-- ===== TITLE SECTION ===== -->
            <VBox alignment="CENTER" spacing="10">

                <Label fx:id="titleLabel" alignment="CENTER" maxWidth="550" styleClass="task-description-lbl" textAlignment="CENTER" wrapText="true" />

                <Label fx:id="stateLabel" alignment="CENTER" styleClass="task-state-lbl" text="STARTED" textAlignment="CENTER" wrapText="true" />

            </VBox>

            <!-- ===== BOTTOM SECTION ===== -->
            <VBox alignment="CENTER" spacing="25">
                <HBox alignment="CENTER_RIGHT">
                    <GridPane fx:id="workersGrid" hgap="15" maxWidth="300" vgap="15">

                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>

                        <rowConstraints>
                            <RowConstraints percentHeight="100" />
                        </rowConstraints>

                    </GridPane>

                </HBox>

                <HBox alignment="CENTER" spacing="20">

                    <Button fx:id="acceptButton" styleClass="styled-btn" text="ACCEPT TASK" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="changeStateButton" styleClass="styled-btn" text="COMPLETE TASK" />

                </HBox>

            </VBox>

        </VBox>
    </center>
</fx:root>
