<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="HBox"
         xmlns="http://javafx.com/javafx/21"
         xmlns:fx="http://javafx.com/fxml/1"
         spacing="10"
         alignment="CENTER">

    <!-- HOUR -->
    <VBox alignment="CENTER">
        <Label text="HOUR" styleClass="info-text-lbl"/>
        <Region prefHeight="10" prefWidth="0"/>
        <TextField fx:id="hourField"
                   promptText="HH"
                   minWidth="60"
                   prefWidth="100"
                   alignment="CENTER"
                   styleClass="input-form"/>
    </VBox>

    <Label text=":" styleClass="info-text-lbl"/>

    <!-- MINUTE -->
    <VBox alignment="CENTER">
        <Label text="MINUTE" styleClass="info-text-lbl"/>
        <Region prefHeight="10" prefWidth="0"/>
        <TextField fx:id="minuteField"
                   promptText="mm"
                   minWidth="60"
                   prefWidth="60"
                   alignment="CENTER"
                   styleClass="input-form"/>
    </VBox>

</fx:root>
